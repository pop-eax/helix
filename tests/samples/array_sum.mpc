// Array Sum — sums all elements of a 4-element secret array.
//
// Demonstrates loop unrolling + compile-time array indexing.
//
// Example:
//   runner array_sum.ir -i "1,2,3,4" -b clear   => output[0]: 10
fn array_sum(Secret Array<Field<64>, 4> arr) -> Field<64> {
    let Public Field<64> s = 0;
    for i in 0..4 {
        s = s + arr[i];
    }
    return s;
}
