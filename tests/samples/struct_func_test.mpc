// Struct-arg function call test.
//
// dot computes the dot product of two 2D vectors.
// main calls dot twice and adds the results.
//
// Example (clear):
//   runner struct_func_test.ir -i "1,2,3,4,5,6,7,8" -b clear
//   => dot(p1,p2) + dot(p3,p4)
//   = (1*3 + 2*4) + (5*7 + 6*8) = 11 + 83 = 94
struct Vec2 {
    Field<64> x;
    Field<64> y;
}

fn dot(Secret Vec2 a, Secret Vec2 b) -> Field<64> {
    return a.x * b.x + a.y * b.y;
}

fn main(Secret Vec2 p1, Secret Vec2 p2, Secret Vec2 p3, Secret Vec2 p4) -> Field<64> {
    let Public Field<64> d1 = dot(p1, p2);
    let Public Field<64> d2 = dot(p3, p4);
    return d1 + d2;
}
